# This file is documentation only — Next.js does not read it on the internet.
# Never commit your real password to GitHub.

# Public site URL for Open Graph, canonicals, and JSON-LD (no trailing slash).
# On Render: https://your-service.onrender.com
# NEXT_PUBLIC_SITE_URL=https://perfectnails.onrender.com

# WHERE TO SET YOUR ADMIN PASSWORD (long-term, business)
# -------------------------------------------------------
# 1. Open https://dashboard.render.com
# 2. Click your Web Service (e.g. perfectnails)
# 3. Go to **Environment** in the left sidebar
# 4. Click **Add Environment Variable**
#    Key:   ADMIN_PASSWORD
#    Value: (choose one strong password you will remember — long phrase or random)
# 5. **Save Changes**
# 6. Trigger a new deploy: **Manual Deploy** → **Deploy latest commit**
#    (needed so the server picks up the new variable)
#
# After that, use that same password on /admin/login on your live site.

# Optional (Render → Environment): separate signing secret so it differs from the password
# ADMIN_SESSION_SECRET=

# Optional (Render → Environment): secret admin path segment
# If set, your admin URLs become:
# - /admin/<SECRET> (dashboard)
# - /admin/<SECRET>/login (login)
# and direct /admin and /admin/login will 404.
# Example:
# ADMIN_PATH_SECRET=admin0410

# --- Amazon S3 (site JSON: services, staff, bookings, about, contact) ---
# Add these in Render → Environment (same Web Service). Redeploy after saving.
#
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-2
# (or AWS_DEFAULT_REGION — either works)
# S3_BUCKET_NAME=your-bucket-name
# Old NailsByNi project uses AWS_S3_BUCKET_NAME — that name is supported too.
# (also: S3_BUCKET, AWS_S3_BUCKET, BUCKET_NAME)
#
# Optional: object key if you share the bucket with other projects (default: cms/site.json)
# S3_SITE_OBJECT_KEY=perfectnails/cms/site.json
#
# IAM user needs s3:GetObject and s3:PutObject on site.json AND on gallery uploads, e.g.:
#   arn:aws:s3:::YOUR-BUCKET/perfectnails/cms/site.json
#   arn:aws:s3:::YOUR-BUCKET/perfectnails/gallery/*
#
# Gallery images are uploaded to S3 and shown with a public HTTPS URL. You need EITHER:
# - Bucket policy allowing s3:GetObject for Principal "*" on prefix perfectnails/gallery/* (recommended), OR
# - CloudFront (or other CDN) in front of the bucket — set AWS_CDN_URL or S3_PUBLIC_BASE_URL to that base URL.
#
# Optional gallery prefix (default: perfectnails/gallery)
# S3_GALLERY_PREFIX=perfectnails/gallery
#
# Optional if you use a CDN for the bucket (same as old NailsByNi AWS_CDN_URL):
# AWS_CDN_URL=https://dxxxx.cloudfront.net

# --- Twilio SMS (booking confirmation + reminders) ---
# Twilio Console → Account Info + Phone Numbers.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+16233022156

# --- Cron security (recommended in production) ---
# Used by POST /api/cron/sms-reminders with header: x-cron-secret: <value>
# CRON_SECRET=
